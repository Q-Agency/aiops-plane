# Copy this file to `.env.local` (gitignored) and fill in real values, then restart the dev
# server. Nitro (TanStack Start's server) loads it into process.env for server functions.
# NEVER put real keys in `.env.example` — this file is committed.

# --- BA agent (the federated system #1) ----------------------------------------------------
BA_AGENT_URL=http://localhost:8000
# BA_AGENT_API_KEY=
# BA_AGENT_AUTH_HEADER=X-API-Key

# --- Audit ledger: the dashboard's OWN Supabase (project "Q AI Ops Plane") -----------------
# URL: Supabase → Project Settings → API → Project URL
DASHBOARD_SUPABASE_URL=https://fwaogfwwusuiqislkbpb.supabase.co
# SECRET (service-role): Supabase → Project Settings → API → Project API keys → service_role.
# Bypasses RLS; server-only. Never expose to the browser or commit it.
DASHBOARD_SUPABASE_SERVICE_ROLE_KEY=

# Optional: the audit ledger's server-side background sync (node-server deploy). It ingests
# each agent's reset/approve events 24/7, independent of any open page. Defaults: enabled,
# every 120s. Set AUDIT_SYNC=off to disable; tune the interval (ms, floor 30s).
# AUDIT_SYNC=off
# AUDIT_SYNC_INTERVAL_MS=120000
